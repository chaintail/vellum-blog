---
import '../styles/global.css';
interface Props {
  title: string;
  description?: string;
  image?: string;
  ogType?: string;
  jsonLd?: unknown;
}
const { title, description, image = '/og/vellum-default.png', ogType = 'website', jsonLd } = Astro.props;
const site = Astro.site ?? new URL('https://blog.vellum.network');
const ogImage = new URL(image, site).href;
const canonical = new URL(Astro.url.pathname, site).href;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Vellum" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImage} />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='6' fill='%23f7f3ea'/%3E%3Ctext x='16' y='23' font-size='20' font-family='Georgia,serif' font-weight='700' text-anchor='middle' fill='%239a3b1f'%3EV%3C/text%3E%3C/svg%3E" />
  </head>
  <body>
    <header class="site-header">
      <div class="wrap">
        <a href="/" class="wordmark" aria-label="Vellum Blog — home">
          <img class="wordmark-mark" src="/img/vellum-mark-blog.png" alt="" />
          <span class="wordmark-lockup">
            <span class="wordmark-name">Vellum</span>
            <span class="wordmark-sub">Blog</span>
          </span>
        </a>
        <span class="tagline">notes on payment rails &amp; protocol design</span>
        <button class="nav-toggle" id="navToggle" aria-label="Toggle menu" aria-expanded="false"><span></span><span></span><span></span></button>
        <nav class="nav-links" id="navLinks">
          <a href="/">Articles</a>
          <a href="https://vellum.network">Home</a>
        </nav>
      </div>
    </header>
    <main>
      <div class="wrap">
        <slot />
      </div>
    </main>

    <div class="zoom-overlay" id="zoomOverlay">
      <span class="zoom-hint">click anywhere or press Esc to close</span>
    </div>
    <script>
      (function () {
        const overlay = document.getElementById('zoomOverlay');
        if (!overlay) return;
        const clear = () => overlay.querySelectorAll('img, svg').forEach((n) => n.remove());
        const close = () => { overlay.classList.remove('open'); clear(); };
        document.addEventListener('click', (e) => {
          if (overlay.classList.contains('open')) { close(); return; }
          const t = e.target;
          if (!t || !t.closest) return;
          const img = t.closest('.prose img');
          if (img && !/\/logos\//.test(img.currentSrc || img.src)) {
            const c = document.createElement('img');
            c.src = img.currentSrc || img.src;
            overlay.appendChild(c);
            overlay.classList.add('open');
            return;
          }
          const mer = t.closest('.prose .mermaid');
          if (mer) {
            const svg = mer.querySelector('svg');
            if (!svg) return;
            const clone = svg.cloneNode(true);
            clone.removeAttribute('width');
            clone.removeAttribute('height');
            clone.removeAttribute('style');
            overlay.appendChild(clone);
            overlay.classList.add('open');
          }
        });
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
      })();
    </script>
    <script>
      (function () {
        const t = document.getElementById('navToggle');
        const n = document.getElementById('navLinks');
        if (!t || !n) return;
        t.addEventListener('click', () => {
          const open = n.classList.toggle('open');
          t.setAttribute('aria-expanded', String(open));
        });
      })();
    </script>
  </body>
</html>
